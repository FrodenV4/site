rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validUsername(value) {
      return value is string
        && value.size() >= 3
        && value.size() <= 24
        && value.matches('^[a-z0-9._-]+$');
    }

    function validEmail(value) {
      return value is string
        && value.size() >= 6
        && value.size() <= 120
        && value.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    function validContact(value) {
      return value is string
        && value.size() >= 3
        && value.size() <= 120;
    }

    function validComment(value) {
      return value is string
        && value.size() <= 260;
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && validUsername(request.resource.data.username)
        && validUsername(request.resource.data.usernameKey)
        && request.resource.data.username == request.resource.data.usernameKey
        && validEmail(request.resource.data.email)
        && request.resource.data.role == "user";
      allow update, delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /productFiles/{productId} {
      allow read, write: if isAdmin();

      match /chunks/{chunkId} {
        allow read, write: if isAdmin();
      }
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && validUsername(request.resource.data.username)
        && validEmail(request.resource.data.email)
        && validContact(request.resource.data.contact)
        && validComment(request.resource.data.comment)
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 20
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.status == "new";

      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
