rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /productFiles/{productId} {
      allow read, write: if isAdmin();

      match /chunks/{chunkId} {
        allow read, write: if isAdmin();
      }
    }

    match /orders/{orderId} {
      allow create: if request.resource.data.contact is string
        && request.resource.data.contact.size() >= 3
        && request.resource.data.contact.size() <= 120
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 260
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 20
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.status == "new";

      allow read, update, delete: if isAdmin();
    }
  }
}
